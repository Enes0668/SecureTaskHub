@page
@model SecureTaskHub.Pages.LoginModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white text-center">
                    <h4>SecureTaskHub Giriş</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">E-posta Adresi</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="örnek@mail.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">Şifre</label>
                            <input asp-for="Input.Password" class="form-control" type="password" placeholder="******" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
                    </form>

                    @if (Model.ErrorMessage != null)
                    {
                        <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
                    }

                    @if (Model.SuccessMessage != null)
                    {
                        <div class="alert alert-success mt-3">@Model.SuccessMessage</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>